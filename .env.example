# API Base URL des Asset-Broker-Backends (FastAPI)
# Beispiel: http://localhost:8888
VITE_API_BASE_URL=

# Bynder Base URL (ohne trailing slash)
# Beispiel: https://your-company.getbynder.com
VITE_BYNDER_BASE_URL=

# OAuth Callback URL (Basis-URL der PWA, ohne Pfad)
# Muss in Bynder OAuth-App als Redirect URI eingetragen sein.
# Beispiel: https://ar-sales.example.com oder http://localhost:5173
VITE_OAUTH_CALLBACK_URL=

# Bynder OAuth Client ID (aus Bynder OAuth-App)
VITE_OAUTH_CLIENT_ID=

# Backend: Katalog nur mit Metaproperty Source=POSM (optional, Default im Backend)
# BYNDER_FILTER_METAPROPERTY_ID=6E5384FB-EA16-417E-8629EB2BFCD7C119
# BYNDER_FILTER_VALUE=POSM
# Backend: nur GLB-Assets anzeigen (optional; Standard: aus)
# BYNDER_FILTER_GLB_ONLY=true

# Backend: nur Assets mit diesem Tag anzeigen (z. B. AR für GLB/AR-fähige Dateien)
# BYNDER_FILTER_TAG=AR

# Backend: Geheimnis für kurzfristige Modell-URLs (für AR / Quick Look). Wenn gesetzt, kann die App eine same-origin-ähnliche Modell-URL anfordern.
# MODEL_URL_SECRET=ein-geheimes-zufalls-string

# Backend: Öffentliche Basis-URL für Modell- und Download-URLs (mit Port falls nötig). Ohne diese Variable nutzt das Backend request.base_url (oft ohne Port → 404).
# Beispiel Pi im LAN: http://192.168.0.150:8888
# PUBLIC_BASE_URL=http://192.168.0.150:8888
