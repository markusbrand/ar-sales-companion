# Bynder (can also use root .env with VITE_* for shared frontend/backend)
BYNDER_BASE_URL=https://your-company.getbynder.com
BYNDER_CLIENT_ID=your-oauth-client-id
BYNDER_CLIENT_SECRET=your-oauth-client-secret

# Optional: callback URL (defaults to VITE_OAUTH_CALLBACK_URL + /auth/callback)
# OAUTH_CALLBACK_URL=http://localhost:5173

# Filter Katalog: nur Assets, bei denen die Metaproperty (Source) den Wert hat
# BYNDER_FILTER_METAPROPERTY_ID=6E5384FB-EA16-417E-8629EB2BFCD7C119
# BYNDER_FILTER_VALUE=POSM

# Nur GLB-Assets im Katalog (Standard: aus; Bynder-Felder für Typ oft anders)
# BYNDER_FILTER_GLB_ONLY=true
